{
	"name": "termux-mcp-server",
	"version": "0.1.0",
	"type": "module",
	"private": true,
	"description": "Termux MCP server with Streamable HTTP transport",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"scripts": {
		"build": "tsc -p tsconfig.json",
		"dev": "tsx src/index.ts",
		"start": "node dist/index.js",
		"check": "tsc --noEmit -p tsconfig.json",
		"test": "pnpm build && tsx --test test/**/*.test.ts"
	},
	"dependencies": {
		"@iarna/toml": "^2.2.5",
		"@modelcontextprotocol/sdk": "^1.27.1",
		"diff": "^8.0.3",
		"fast-glob": "^3.3.3",
		"minimatch": "^10.2.4",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@types/node": "^25.5.0",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3"
	}
}
